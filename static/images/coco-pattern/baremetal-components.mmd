graph TB
    subgraph "Hardware Layer"
        H1[Intel TDX CPU]
        H2[AMD SEV-SNP CPU]
        H3[NVIDIA H100 GPU<br/>Optional]
    end

    subgraph "Detection & Labeling"
        NFD[Node Feature Discovery]
        NFD -->|Detects TDX| L1[intel.feature.node.kubernetes.io/tdx=true]
        NFD -->|Detects SEV-SNP| L2[amd.feature.node.kubernetes.io/snp=true]
        NFD -->|Detects SGX| L3[intel.feature.node.kubernetes.io/sgx=true]
    end

    subgraph "MachineConfig"
        MC1[Kernel Parameters]
        MC1 -->|Intel| MC1A[kvm_intel.tdx=1<br/>intel_iommu=on]
        MC1 -->|AMD| MC1B[amd_iommu=on]
        MC1 -->|All| MC1C[nohibernate<br/>vsock module]
    end

    subgraph "Intel TDX Stack"
        PCCS[PCCS Service<br/>Attestation Collateral Cache]
        QGS[QGS DaemonSet<br/>Quote Generation]
        SGX[SGX Device Plugin]
        PCCS -->|Intel PCS API| Intel[Intel Trusted Services]
        QGS -->|nodeSelector| L1
        SGX -->|nodeSelector| L3
    end

    subgraph "RuntimeClass Selection"
        OSC[OSC Operator]
        OSC --> RT1[kata-tdx RuntimeClass]
        OSC --> RT2[kata-snp RuntimeClass]
        OSC --> RT3[kata-cc-nvidia-gpu RuntimeClass]
        RT1 -.nodeSelector.-> L1
        RT2 -.nodeSelector.-> L2
        RT3 -.nodeSelector.-> L1
    end

    subgraph "GPU Stack (baremetal-gpu only)"
        GPUOP[NVIDIA GPU Operator]
        GPUOP --> CCM[CC Manager<br/>Confidential Mode]
        GPUOP --> VFIO[VFIO Manager<br/>GPU Passthrough]
        GPUOP --> KATA[Kata Device Plugin<br/>nvidia.com/pgpu]
        VFIO -.requires.-> MC1A
        VFIO -.requires.-> MC1B
    end

    subgraph "Storage"
        LVMS[LVMS Operator]
        LVMS -->|Auto-discovers| BLK[Block Devices]
    end

    H1 -.-> NFD
    H2 -.-> NFD
    H3 -.-> GPUOP

    style NFD fill:#d4e6f1
    style OSC fill:#d4e6f1
    style PCCS fill:#e8daef
    style QGS fill:#e8daef
    style GPUOP fill:#fdebd0
    style LVMS fill:#d5f4e6
