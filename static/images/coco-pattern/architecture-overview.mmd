graph TB
    subgraph "Deployment Topologies"
        subgraph "Azure Cloud"
            A1["simple<br/>(Single Cluster)"]
            A2["trusted-hub + spoke<br/>(Multi-Cluster)"]
        end
        subgraph "Bare Metal"
            B1["baremetal<br/>(TDX / SEV-SNP)"]
            B2["baremetal-gpu<br/>(TDX + H100 GPU)"]
        end
    end

    subgraph "Trusted Zone"
        T1[Trustee KBS]
        T2[Attestation Service]
        T3[HashiCorp Vault]
        T4[cert-manager]
    end

    subgraph "Untrusted Zone"
        U1[Kyverno]
        U2[OSC Operator]
        U3[Confidential Workloads]
        U4[CDH]
    end

    subgraph "Platform Components"
        P1[NFD<br/>Bare Metal Only]
        P2[Intel DCAP<br/>TDX Only]
        P3[NVIDIA GPU Operator<br/>GPU Only]
    end

    A1 & A2 --> T1
    B1 & B2 --> T1

    T1 --> T2
    T2 --> T3
    T3 --> T4

    U1 --> U2
    U2 --> U3
    U3 --> U4
    U4 -.Attestation.-> T1

    B1 & B2 --> P1
    B1 & B2 --> P2
    B2 --> P3

    style T1 fill:#e1f5ff
    style T2 fill:#e1f5ff
    style T3 fill:#e1f5ff
    style T4 fill:#e1f5ff
    style U1 fill:#fff4e1
    style U2 fill:#fff4e1
    style U3 fill:#fff4e1
    style U4 fill:#fff4e1
